# Temporary files
*.tmp
.temp/

# Documentation directories (kept separate)
文档/

# DevBoost CLI config (contains sensitive API keys)
.devboost/models.json
.devboost/telegram.json

# Ignore .devboost in subdirectories (only keep root .devboost)
**/.devboost/
!/.devboost/

# But keep conversation history and context in root .devboost
!.devboost/context/
!.devboost/sessions/
!.devboost/history/
